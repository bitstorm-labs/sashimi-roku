{
  "rootDir": ".",
  "stagingDir": "out",
  "retainStagingDir": true,
  "files": [
    "manifest",
    "source/**/*",
    "components/**/*",
    "images/**/*",
    "locale/**/*",
    "fonts/**/*"
  ],
  "autoImportComponentScript": true,
  "sourceMap": true,
  "diagnosticFilters": [
    {
      "src": "tests/**/*"
    }
  ]
}