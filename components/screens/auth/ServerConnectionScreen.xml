<?xml version="1.0" encoding="UTF-8" ?>
<component name="ServerConnectionScreen" extends="Group">
    <interface>
        <field id="loginSuccess" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#0e0e1a" />

        <!-- Centered title -->
        <Label
            text="Sashimi"
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            horizAlign="center"
            width="1920"
            translation="[0, 140]"
        />
        <Label
            text="Connect to your Jellyfin server"
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 210]"
        />

        <!-- Form card -->
        <Rectangle
            id="formBg"
            translation="[560, 300]"
            width="800"
            height="440"
            color="#101420"
        />

        <!-- Form buttons -->
        <ButtonGroup
            id="formButtons"
            translation="[600, 330]"
            minWidth="720"
            buttonHeight="64"
            itemSpacings="[14]"
            textFont="font:MediumSystemFont"
            focusedTextFont="font:MediumBoldSystemFont"
            textColor="#888888"
            focusedTextColor="#FFFFFF"
            focusBitmapUri="pkg:/images/button_focus.png"
            focusFootprintBitmapUri="pkg:/images/button_unfocus.png"
        />

        <!-- Status -->
        <Label
            id="statusLabel"
            text=""
            font="font:SmallSystemFont"
            color="#FF6666"
            horizAlign="center"
            width="1920"
            translation="[0, 790]"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Connecting..."
            font="font:MediumSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <!-- Discovery panel -->
        <Rectangle
            id="discoveryBg"
            translation="[560, 300]"
            width="800"
            height="440"
            color="#101420"
            visible="false"
        />
        <Label
            id="discoveryTitle"
            text="Select a Server"
            font="font:MediumBoldSystemFont"
            color="#FFFFFF"
            translation="[600, 320]"
            visible="false"
        />
        <LabelList
            id="serverList"
            translation="[600, 380]"
            itemSize="[720, 52]"
            numRows="6"
            visible="false"
        />

        <ErrorDialog id="errorDialog" />
        <JellyfinApi id="apiTask" />
        <ServerDiscoveryTask id="discoveryTask" />
    </children>
</component>
