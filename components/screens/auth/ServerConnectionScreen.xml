<?xml version="1.0" encoding="UTF-8" ?>
<component name="ServerConnectionScreen" extends="Group">
    <interface>
        <field id="loginSuccess" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#0e0e1a" />

        <!-- Title area (centered, in title safe zone) -->
        <Label
            text="Sashimi"
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            horizAlign="center"
            width="1920"
            translation="[0, 120]"
        />
        <Label
            text="Connect to your Jellyfin server"
            font="font:SmallSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 190]"
        />

        <!-- Form card background -->
        <Rectangle
            id="formBg"
            translation="[460, 280]"
            width="1000"
            height="480"
            color="#101420"
        />

        <!-- Form buttons -->
        <ButtonGroup
            id="formButtons"
            translation="[510, 310]"
            minWidth="900"
            buttonHeight="72"
            itemSpacings="[16]"
            textFont="font:MediumSystemFont"
            focusedTextFont="font:MediumBoldSystemFont"
            textColor="#AAAAAA"
            focusedTextColor="#FFFFFF"
            focusBitmapUri="pkg:/images/button_focus.png"
            focusFootprintBitmapUri="pkg:/images/button_unfocus.png"
        />

        <!-- Status message -->
        <Label
            id="statusLabel"
            text=""
            font="font:SmallSystemFont"
            color="#FF6666"
            horizAlign="center"
            width="1920"
            translation="[0, 800]"
        />

        <!-- Loading text -->
        <Label
            id="loadingLabel"
            text="Connecting..."
            font="font:MediumBoldSystemFont"
            color="#CCCCCC"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <!-- Discovered servers panel -->
        <Rectangle
            id="discoveryBg"
            translation="[460, 280]"
            width="1000"
            height="480"
            color="#101420"
            visible="false"
        />
        <Label
            id="discoveryTitle"
            text="Select a Server"
            font="font:MediumBoldSystemFont"
            color="#FFFFFF"
            translation="[510, 300]"
            visible="false"
        />
        <LabelList
            id="serverList"
            translation="[510, 370]"
            itemSize="[900, 60]"
            numRows="5"
            visible="false"
        />

        <!-- Error Dialog -->
        <ErrorDialog id="errorDialog" />

        <!-- API Task -->
        <JellyfinApi id="apiTask" />

        <!-- Server Discovery Task -->
        <ServerDiscoveryTask id="discoveryTask" />
    </children>
</component>
