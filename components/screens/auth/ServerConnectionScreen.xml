<?xml version="1.0" encoding="UTF-8" ?>
<component name="ServerConnectionScreen" extends="Group">
    <interface>
        <field id="loginSuccess" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#1a1a2e" />

        <!-- Title -->
        <Label
            id="titleLabel"
            text="Sashimi"
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            horizAlign="center"
            width="1920"
            translation="[0, 80]"
        />
        <Label
            id="subtitleLabel"
            text="Jellyfin Client"
            font="font:SmallSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 150]"
        />

        <!-- Form container -->
        <Rectangle
            id="formBg"
            translation="[510, 240]"
            width="900"
            height="520"
            color="#252545"
        />

        <!-- Form buttons (ButtonGroup handles D-pad automatically) -->
        <ButtonGroup
            id="formButtons"
            translation="[560, 270]"
            minWidth="800"
            itemSpacings="[12]"
        />

        <!-- Status label -->
        <Label
            id="statusLabel"
            text=""
            font="font:SmallSystemFont"
            color="#FF6666"
            horizAlign="center"
            width="1920"
            translation="[0, 810]"
        />

        <!-- Loading indicator -->
        <Label
            id="loadingLabel"
            text="Connecting..."
            font="font:MediumSystemFont"
            color="#CCCCCC"
            horizAlign="center"
            width="1920"
            translation="[0, 540]"
            visible="false"
        />

        <!-- Discovered servers panel -->
        <Rectangle
            id="discoveryBg"
            translation="[1050, 240]"
            width="450"
            height="400"
            color="#252545"
            visible="false"
        />
        <Label
            id="discoveryTitle"
            text="Discovered Servers"
            font="font:SmallSystemFont"
            color="#AAAAAA"
            translation="[1070, 250]"
            visible="false"
        />
        <LabelList
            id="serverList"
            translation="[1070, 290]"
            itemSize="[410, 48]"
            numRows="6"
            visible="false"
        />

        <!-- Error Dialog -->
        <ErrorDialog id="errorDialog" />

        <!-- API Task -->
        <JellyfinApi id="apiTask" />

        <!-- Server Discovery Task -->
        <ServerDiscoveryTask id="discoveryTask" />
    </children>
</component>
