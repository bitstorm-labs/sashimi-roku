<?xml version="1.0" encoding="UTF-8" ?>
<component name="MediaDetailScreen" extends="Group">
    <interface>
        <field id="itemData" type="assocarray" onChange="onItemDataChanged" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="playItem" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#121215" />

        <!-- Full-screen backdrop -->
        <Poster
            id="backdropImage"
            width="1920"
            height="1080"
            loadWidth="960"
            loadHeight="540"
            loadDisplayMode="scaleToZoom"
            opacity="0.2"
        />
        <!-- Strong left gradient for text readability -->
        <Rectangle width="900" height="1080" color="#121215" opacity="0.85" />
        <Rectangle width="400" height="1080" color="#121215" opacity="0.4" translation="[900, 0]" />

        <!-- Poster -->
        <Poster
            id="posterImage"
            translation="[96, 80]"
            width="320"
            height="480"
            loadWidth="320"
            loadHeight="480"
            loadDisplayMode="scaleToZoom"
        />

        <!-- Title area -->
        <Label
            id="titleLabel"
            text=""
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            width="1400"
            maxLines="2"
            translation="[460, 80]"
        />
        <Label
            id="subtitleLabel"
            text=""
            font="font:MediumSystemFont"
            color="#AAAAAA"
            width="1400"
            translation="[460, 165]"
        />
        <Label
            id="metadataLabel"
            text=""
            font="font:SmallSystemFont"
            color="#777777"
            width="1400"
            translation="[460, 210]"
        />
        <Label
            id="overviewLabel"
            text=""
            font="font:SmallSystemFont"
            color="#BBBBBB"
            width="1050"
            maxLines="6"
            wrap="true"
            translation="[460, 260]"
        />

        <!-- Action buttons -->
        <ButtonGroup
            id="actionButtons"
            translation="[460, 440]"
            minWidth="200"
            buttonHeight="52"
            itemSpacings="[12]"
            layoutDirection="horiz"
            textFont="font:SmallSystemFont"
            focusedTextFont="font:SmallBoldSystemFont"
            textColor="#888888"
            focusedTextColor="#FFFFFF"
            focusBitmapUri="pkg:/images/button_focus.png"
            focusFootprintBitmapUri="pkg:/images/button_unfocus.png"
        />

        <!-- Related content -->
        <RowList
            id="relatedContent"
            translation="[96, 530]"
            itemSize="[1728, 410]"
            numRows="2"
            itemSpacing="[0, 10]"
            rowItemSize="[[240, 390]]"
            rowItemSpacing="[[20, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            drawFocusFeedback="false"
            rowLabelFont="font:MediumBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 8]]"
            rowFocusAnimationStyle="fixedFocusWrap"
            itemComponentName="HomeItem"
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading..."
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 480]"
            visible="true"
        />

        <JellyfinApi id="apiTask" />
    </children>
</component>
