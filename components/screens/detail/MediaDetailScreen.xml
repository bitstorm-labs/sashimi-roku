<?xml version="1.0" encoding="UTF-8" ?>
<component name="MediaDetailScreen" extends="Group">
    <interface>
        <field id="itemData" type="assocarray" onChange="onItemDataChanged" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="playItem" type="assocarray" alwaysNotify="true" />
        <field id="autoPlay" type="boolean" value="false" />
    </interface>
    <children>
        <!-- Background (matches app gradient) -->
        <Poster uri="pkg:/images/bg_gradient.png" width="1920" height="1080" />

        <!-- Backdrop: top-right, fitted, feathered left edge (tvOS Plex-style) -->
        <Poster id="backdropImage" width="864" height="580" loadWidth="1728" loadHeight="1160"
                loadDisplayMode="scaleToFit" translation="[916, 60]" />
        <Poster id="backdropFadeLeft" uri="pkg:/images/hero_fade_left.png"
                width="420" height="580" translation="[916, 60]" />
        <Poster id="backdropFadeBottom" uri="pkg:/images/hero_fade_bottom.png"
                width="1004" height="200" translation="[916, 440]" />

        <!-- ===== Fixed header ===== -->
        <Poster id="logoImage" width="760" height="210" loadDisplayMode="scaleToFit"
                translation="[60, 60]" visible="false" />
        <MaskGroup id="moviePosterMask" maskUri="pkg:/images/poster_mask_r12.png"
                   maskSize="[200, 300]" translation="[60, 60]" visible="false">
            <Poster id="moviePoster" width="200" height="300" loadWidth="400" loadHeight="600"
                    loadDisplayMode="scaleToZoom" />
        </MaskGroup>
        <MaskGroup id="channelMask" maskUri="pkg:/images/circle_mask.png"
                   maskSize="[120, 120]" translation="[60, 60]" visible="false">
            <Poster id="channelImage" width="120" height="120" loadWidth="240" loadHeight="240"
                    loadDisplayMode="scaleToZoom" />
        </MaskGroup>

        <Label id="titleLabel" text="" color="#FFFFFF" width="1000" maxLines="2" translation="[60, 250]">
            <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="38" />
        </Label>
        <Label id="endsAtLabel" text="" color="#5BADE6" maxLines="1" translation="[60, 312]">
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="22" />
        </Label>
        <Label id="metaLabel" text="" color="#BFBFBF" maxLines="1" translation="[60, 312]">
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="22" />
        </Label>

        <Group id="ratingsGroup" translation="[60, 352]">
            <Poster id="tmdbLogo" uri="pkg:/images/tmdb_logo_tv.png" width="34" height="24"
                    loadDisplayMode="scaleToFit" visible="false" />
            <Label id="tmdbScore" text="" color="#FFFFFF" height="24" vertAlign="center" translation="[44, 0]" visible="false">
                <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="20" />
            </Label>
            <Poster id="tomatoIcon" uri="pkg:/images/tomato.png" width="24" height="24"
                    translation="[140, 0]" visible="false" />
            <Label id="tomatoScore" text="" color="#FFFFFF" height="24" vertAlign="center" translation="[172, 0]" visible="false">
                <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="20" />
            </Label>
        </Group>

        <Group id="badgesGroup" translation="[280, 352]" />
        <Group id="tagsGroup" translation="[60, 446]" />

        <Label id="genresLabel" text="" color="#BFBFBF" width="1000" maxLines="1" translation="[60, 448]">
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="22" />
        </Label>

        <Label id="overviewLabel" text="" color="#BFBFBF" width="940" maxLines="2"
               wrap="true" translation="[60, 488]">
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="24" />
        </Label>

        <!-- Action buttons (focusable component) -->
        <DetailButtons id="detailButtons" translation="[60, 596]" />

        <!-- ===== One multi-row RowList: seasons / episodes / cast ===== -->
        <RowList
            id="rowList"
            translation="[60, 700]"
            itemSize="[1800, 300]"
            numRows="2"
            itemSpacing="[0, 20]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            drawFocusFeedback="false"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 8]]"
            rowFocusAnimationStyle="fixedFocus"
            itemComponentName="DetailRowItem"
            visible="false"
        />

        <Label id="loadingLabel" text="Loading..." color="#8C8C8C"
               horizAlign="center" width="1920" translation="[0, 500]" visible="false">
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="28" />
        </Label>

        <JellyfinApi id="apiTask" />
    </children>
</component>
