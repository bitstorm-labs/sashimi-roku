<?xml version="1.0" encoding="UTF-8" ?>
<component name="MediaDetailScreen" extends="Group">
    <interface>
        <field id="itemData" type="assocarray" onChange="onItemDataChanged" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="playItem" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#0e0e1a" />

        <!-- Backdrop image — full screen, heavily dimmed -->
        <Poster
            id="backdropImage"
            width="1920"
            height="1080"
            loadWidth="960"
            loadHeight="540"
            loadDisplayMode="scaleToZoom"
            opacity="0.25"
        />
        <!-- Dark gradient overlay from left (content area) to right (image area) -->
        <Rectangle id="backdropGradient" width="1100" height="1080" color="#0e0e1a" opacity="0.7" />

        <!-- Poster image — left side -->
        <Poster
            id="posterImage"
            translation="[96, 100]"
            width="280"
            height="420"
            loadWidth="280"
            loadHeight="420"
            loadDisplayMode="scaleToZoom"
        />

        <!-- Content area — right of poster -->
        <Label
            id="titleLabel"
            text=""
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            width="1400"
            maxLines="2"
            translation="[420, 100]"
        />
        <Label
            id="subtitleLabel"
            text=""
            font="font:MediumSystemFont"
            color="#AAAAAA"
            width="1400"
            translation="[420, 180]"
        />
        <Label
            id="metadataLabel"
            text=""
            font="font:SmallSystemFont"
            color="#888888"
            width="1400"
            translation="[420, 225]"
        />
        <Label
            id="overviewLabel"
            text=""
            font="font:SmallSystemFont"
            color="#BBBBBB"
            width="1100"
            maxLines="5"
            wrap="true"
            translation="[420, 270]"
        />

        <!-- Action buttons — horizontal row below content -->
        <ButtonGroup
            id="actionButtons"
            translation="[420, 430]"
            minWidth="220"
            buttonHeight="56"
            itemSpacings="[12]"
            layoutDirection="horiz"
            textFont="font:SmallSystemFont"
            focusedTextFont="font:SmallBoldSystemFont"
            textColor="#AAAAAA"
            focusedTextColor="#FFFFFF"
            focusBitmapUri="pkg:/images/button_focus.png"
            focusFootprintBitmapUri="pkg:/images/button_unfocus.png"
        />

        <!-- Related content rows — bottom section -->
        <RowList
            id="relatedContent"
            translation="[96, 530]"
            itemSize="[1728, 400]"
            numRows="2"
            itemSpacing="[0, 20]"
            rowItemSize="[[240, 380]]"
            rowItemSpacing="[[24, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            rowLabelFont="font:MediumBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 10]]"
            rowFocusAnimationStyle="fixedFocusWrap"
            focusBitmapUri=""
            focusFootprintBitmapUri=""
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading..."
            font="font:MediumSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 480]"
            visible="true"
        />

        <JellyfinApi id="apiTask" />
    </children>
</component>
