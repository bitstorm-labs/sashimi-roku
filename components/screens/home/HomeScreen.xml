<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signOut" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="openSearch" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#0e0e1a" />

        <!-- Dynamic backdrop (updates with focused item) -->
        <Poster
            id="backdrop"
            width="1920"
            height="1080"
            loadWidth="960"
            loadHeight="540"
            loadDisplayMode="scaleToZoom"
            opacity="0.15"
        />
        <!-- Left gradient for readability -->
        <Rectangle width="800" height="1080" color="#0e0e1a" opacity="0.8" />

        <!-- Header -->
        <Rectangle id="headerBg" width="1920" height="80" color="#0e0e1a" opacity="0.85" />
        <Label
            id="headerTitle"
            text="Sashimi"
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            translation="[96, 14]"
        />
        <Label
            id="headerUser"
            text=""
            font="font:SmallSystemFont"
            color="#555555"
            horizAlign="right"
            width="1728"
            translation="[96, 28]"
        />

        <!-- Content rows -->
        <RowList
            id="rowList"
            translation="[96, 95]"
            itemSize="[1728, 430]"
            numRows="3"
            itemSpacing="[0, 10]"
            rowItemSize="[[240, 410]]"
            rowItemSpacing="[[20, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            drawFocusFeedback="false"
            rowLabelFont="font:MediumBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 8]]"
            rowFocusAnimationStyle="fixedFocusWrap"
            itemComponentName="HomeItem"
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading your library..."
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="true"
        />

        <!-- Empty state -->
        <Label
            id="emptyLabel"
            text=""
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <JellyfinApi id="apiTask" />
        <ToastOverlay id="toast" />
    </children>
</component>
