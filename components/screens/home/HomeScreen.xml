<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signOut" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="openSearch" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#0e0e1a" />

        <!-- Header bar -->
        <Rectangle id="headerBg" width="1920" height="90" color="#101420" />
        <Label
            id="headerTitle"
            text="Sashimi"
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            translation="[96, 18]"
        />
        <Label
            id="headerUser"
            text=""
            font="font:SmallSystemFont"
            color="#666666"
            horizAlign="right"
            width="1728"
            translation="[96, 30]"
        />

        <!-- Main content rows -->
        <RowList
            id="rowList"
            translation="[96, 120]"
            itemSize="[1728, 420]"
            numRows="3"
            itemSpacing="[0, 30]"
            focusBitmapUri=""
            focusFootprintBitmapUri=""
            rowItemSize="[[240, 400]]"
            rowItemSpacing="[[24, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            rowLabelFont="font:MediumBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 10]]"
            rowFocusAnimationStyle="fixedFocusWrap"
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading your library..."
            font="font:MediumSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 480]"
            visible="true"
        />

        <!-- Empty state -->
        <Label
            id="emptyLabel"
            text=""
            font="font:MediumSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 480]"
            visible="false"
        />

        <JellyfinApi id="apiTask" />
        <ToastOverlay id="toast" />
    </children>
</component>
