<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signOut" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="openSearch" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedLibrary" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#121215" />

        <!-- Header -->
        <Rectangle id="headerBg" width="1920" height="80" color="#121215" opacity="0.85" />
        <Poster
            id="headerLogo"
            translation="[96, 16]"
            width="53"
            height="40"
            loadWidth="80"
            loadHeight="60"
            uri="pkg:/images/logo.png"
            loadDisplayMode="scaleToFit"
        />
        <Label
            id="headerTitle"
            text="Sashimi"
            font="font:MediumBoldSystemFont"
            color="#FFFFFF"
            translation="[158, 20]"
        />
        <!-- User avatar (circular with image) -->
        <Rectangle
            id="avatarBg"
            translation="[1810, 22]"
            width="44"
            height="44"
            color="#2a2a4a"
        />
        <MaskGroup
            id="avatarMask"
            translation="[1812, 24]"
            maskUri="pkg:/images/avatar_mask.png"
            maskSize="[40, 40]"
        >
            <Poster
                id="headerAvatar"
                width="40"
                height="40"
                loadWidth="100"
                loadHeight="100"
                loadDisplayMode="scaleToZoom"
            />
        </MaskGroup>
        <!-- Fallback initial if image doesn't load -->
        <Label
            id="avatarLabel"
            translation="[1812, 24]"
            width="40"
            height="40"
            horizAlign="center"
            vertAlign="center"
            font="font:SmallBoldSystemFont"
            color="#FFFFFF"
            text=""
        />

        <!-- Hero Banner -->
        <HeroBanner
            id="heroBanner"
            translation="[96, 80]"
            visible="false"
        />

        <!-- Content rows -->
        <RowList
            id="rowList"
            translation="[96, 520]"
            itemSize="[1728, 400]"
            numRows="3"
            itemSpacing="[0, 10]"
            rowItemSize="[[180, 330]]"
            rowItemSpacing="[[30, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            drawFocusFeedback="false"
            rowLabelFont="font:MediumBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 12]]"
            rowFocusAnimationStyle="fixedFocus"
            itemComponentName="HomeItem"
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading your library..."
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="true"
        />

        <!-- Empty state -->
        <Label
            id="emptyLabel"
            text=""
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <JellyfinApi id="apiTask" />
        <ToastOverlay id="toast" />
    </children>
</component>
