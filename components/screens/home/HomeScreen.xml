<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signOut" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="openSearch" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedLibrary" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background (tvOS: vertical gradient background -> black) -->
        <Poster uri="pkg:/images/bg_gradient.png" width="1920" height="1080" />

        <!-- Header (tvOS AppHeader: logo artwork left, avatar top-right, no bar) -->
        <Poster
            id="headerLogo"
            translation="[30, 22]"
            width="93"
            height="70"
            loadWidth="186"
            loadHeight="140"
            uri="pkg:/images/wordmark.png"
            loadDisplayMode="scaleToFit"
        />
        <!-- User avatar (tvOS: 70x70 accent-gradient circle, user image when available) -->
        <Poster
            id="avatarBg"
            uri="pkg:/images/avatar_accent.png"
            width="70"
            height="70"
            translation="[1820, 22]"
        />
        <Label
            id="avatarLabel"
            translation="[1820, 22]"
            width="70"
            height="70"
            horizAlign="center"
            vertAlign="center"
            color="#FFFFFF"
            text=""
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="28" />
        </Label>
        <MaskGroup
            id="avatarImageMask"
            translation="[1820, 22]"
            maskUri="pkg:/images/circle_mask.png"
            maskSize="[70, 70]"
        >
            <Poster
                id="avatarImage"
                width="70"
                height="70"
                loadWidth="140"
                loadHeight="140"
                loadDisplayMode="scaleToZoom"
            />
        </MaskGroup>

        <!-- Hero Banner (tvOS: 32:9 featured card) -->
        <HeroBanner
            id="heroBanner"
            translation="[50, 122]"
            visible="false"
        />

        <!-- Content rows (tvOS: H-pad 80 via 50 + RowList internal 30... items inset at 30) -->
        <RowList
            id="rowList"
            translation="[80, 674]"
            itemSize="[1820, 450]"
            numRows="2"
            itemSpacing="[0, 30]"
            rowItemSize="[[220, 400]]"
            rowItemSpacing="[[40, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            drawFocusFeedback="false"
            rowLabelFont="font:LargeBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 16]]"
            rowFocusAnimationStyle="fixedFocus"
            itemComponentName="HomeItem"
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading your library..."
            font="font:MediumSystemFont"
            color="#8C8C8C"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="true"
        />

        <!-- Empty state -->
        <Label
            id="emptyLabel"
            text=""
            font="font:MediumSystemFont"
            color="#8C8C8C"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <JellyfinApi id="apiTask" />
    </children>
</component>
