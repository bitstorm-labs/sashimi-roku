<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signOut" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="openSearch" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <children>
        <Rectangle width="1920" height="1080" color="#0e0e1a" />

        <Rectangle id="headerBg" width="1920" height="80" color="#101420" opacity="0.9" />
        <Label
            id="headerTitle"
            text="Sashimi"
            font="font:MediumBoldSystemFont"
            color="#FFFFFF"
            translation="[192, 20]"
        />
        <Label
            id="headerUser"
            text=""
            font="font:SmallSystemFont"
            color="#888888"
            horizAlign="right"
            width="1536"
            translation="[192, 25]"
        />

        <RowList
            id="rowList"
            translation="[130, 100]"
            itemSize="[1660, 400]"
            numRows="4"
            itemSpacing="[0, 20]"
            focusBitmapUri=""
            focusFootprintBitmapUri=""
            rowItemSize="[[230, 380]]"
            rowItemSpacing="[[20, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            rowLabelFont="font:MediumBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowFocusAnimationStyle="fixedFocusWrap"
            visible="false"
        />

        <Label
            id="loadingLabel"
            text="Loading..."
            font="font:MediumSystemFont"
            color="#CCCCCC"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="true"
        />

        <Label
            id="emptyLabel"
            text=""
            font="font:MediumSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <JellyfinApi id="apiTask" />
        <ToastOverlay id="toast" />
    </children>
</component>
