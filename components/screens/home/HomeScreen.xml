<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signOut" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="openSearch" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedLibrary" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background (tvOS: vertical gradient background -> black) -->
        <Poster uri="pkg:/images/bg_gradient.png" width="1920" height="1080" />

        <!-- Logo + avatar now live in the pullout Sidebar -->

        <!-- Hero Banner (tvOS: 32:9 featured card) -->
        <!-- Hero scale lives in HeroBanner.bs (m.baseScale) — one source of truth -->
        <!-- x=-18 centers the SCALED banner in the area right of the rail: the
             screen group sits at +136 (rail), and the 0.84 scale about
             scaleRotateCenter x=910 renders the left edge at tx + 910*(1-0.84)
             = tx+145.6. Visible width 1920-136=1784, scaled banner 1529 ->
             equal ~128px margins needs rendered-left 127.6 -> tx = -18.
             (The old tx=50 predated the rail offset: 196px left / 60px right,
             i.e. the banner sat visibly right of center.) -->
        <HeroBanner
            id="heroBanner"
            translation="[-18, 122]"
            visible="false"
        />

        <!-- Content rows (tvOS: H-pad 80 via 50 + RowList internal 30... items inset at 30) -->
        <!-- y=592: 40px under the 84%-scaled hero (122 + 512*0.84) -->
        <RowList
            id="rowList"
            translation="[80, 592]"
            itemSize="[1820, 450]"
            numRows="2"
            itemSpacing="[0, 30]"
            rowItemSize="[[220, 400]]"
            rowItemSpacing="[[40, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            drawFocusFeedback="false"
            rowLabelFont="font:LargeBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 16]]"
            rowFocusAnimationStyle="fixedFocus"
            itemComponentName="HomeItem"
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading your library..."
            font="font:MediumSystemFont"
            color="#8C8C8C"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="true"
        />

        <!-- Empty state -->
        <Label
            id="emptyLabel"
            text=""
            font="font:MediumSystemFont"
            color="#8C8C8C"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <Animation id="heroSlideAnim" duration="0.3" easeFunction="outQuad">
            <Vector2DFieldInterpolator id="rowsInterp" key="[0.0,1.0]" keyValue="[[80.0,592.0],[80.0,150.0]]" fieldToInterp="rowList.translation" />
            <FloatFieldInterpolator id="heroFadeInterp" key="[0.0,1.0]" keyValue="[1.0,0.0]" fieldToInterp="heroBanner.opacity" />
        </Animation>

        <JellyfinApi id="apiTask" />
        <!-- Fires one tick after nil-ing the RowList content so recycled item
             components are actually discarded before the new content lands —
             otherwise a reload-on-return reuses a portrait cell for a landscape
             Continue Watching card (wrong width sticks). -->
        <Timer id="relayoutTimer" duration="0.05" repeat="false" />
    </children>
</component>
