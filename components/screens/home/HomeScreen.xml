<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <field id="signOut" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="openSearch" type="boolean" value="false" alwaysNotify="true" />
        <field id="selectedLibrary" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#121215" />

        <!-- Header -->
        <Rectangle id="headerBg" width="1920" height="80" color="#121215" opacity="0.85" />
        <Poster
            id="headerLogo"
            translation="[96, 10]"
            width="53"
            height="40"
            loadWidth="80"
            loadHeight="60"
            uri="pkg:/images/logo.png"
            loadDisplayMode="scaleToFit"
        />
        <Label
            id="headerTitle"
            text="Sashimi"
            font="font:MediumBoldSystemFont"
            color="#FFFFFF"
            translation="[158, 14]"
        />
        <!-- User avatar (circular) -->
        <MaskGroup
            id="avatarMask"
            translation="[1800, 15]"
            maskUri="pkg:/images/avatar_mask.png"
            maskSize="[50, 50]"
        >
            <Poster
                id="headerAvatar"
                width="50"
                height="50"
                loadWidth="100"
                loadHeight="100"
                loadDisplayMode="scaleToZoom"
            />
        </MaskGroup>

        <!-- Content rows -->
        <RowList
            id="rowList"
            translation="[96, 95]"
            itemSize="[1728, 480]"
            numRows="2"
            itemSpacing="[0, 10]"
            rowItemSize="[[180, 330]]"
            rowItemSpacing="[[30, 0]]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            drawFocusFeedback="false"
            rowLabelFont="font:LargeBoldSystemFont"
            rowLabelColor="#FFFFFF"
            rowLabelOffset="[[0, 12]]"
            rowFocusAnimationStyle="fixedFocusWrap"
            itemComponentName="HomeItem"
            visible="false"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading your library..."
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="true"
        />

        <!-- Empty state -->
        <Label
            id="emptyLabel"
            text=""
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1920"
            translation="[0, 500]"
            visible="false"
        />

        <JellyfinApi id="apiTask" />
        <ToastOverlay id="toast" />
    </children>
</component>
