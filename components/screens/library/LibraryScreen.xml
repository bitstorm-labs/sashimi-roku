<?xml version="1.0" encoding="UTF-8" ?>
<component name="LibraryScreen" extends="Group">
    <interface>
        <field id="libraryData" type="assocarray" onChange="onLibraryDataChanged" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
        <field id="playItem" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#121215" />

        <!-- Header -->
        <Rectangle width="1920" height="90" color="#101420" />
        <Label
            id="headerTitle"
            text=""
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            translation="[96, 18]"
        />
        <Label
            id="filterLabel"
            text="Sort: Name | Press * for options"
            font="font:SmallestSystemFont"
            color="#666666"
            horizAlign="right"
            width="1360"
            translation="[96, 30]"
        />
        <!-- Shuffle button (header; focusable via Up from the grid) -->
        <Group id="shuffleBtn" translation="[1490, 20]">
            <Rectangle id="shuffleBg" width="220" height="50" color="#2A2A33FF" />
            <Label text="Shuffle" color="#FFFFFF" width="220" height="50" horizAlign="center" vertAlign="center">
                <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="26" />
            </Label>
        </Group>

        <!-- Content grid -->
        <MarkupGrid
            id="posterGrid"
            translation="[96, 120]"
            itemSize="[240, 380]"
            itemSpacing="[30, 40]"
            numColumns="6"
            numRows="3"
            drawFocusFeedback="true"
            focusBitmapUri="pkg:/images/focus_ring_r16.9.png"
            itemComponentName="GridItem"
        />

        <!-- Loading -->
        <Label
            id="loadingLabel"
            text="Loading..."
            font="font:MediumSystemFont"
            color="#888888"
            horizAlign="center"
            width="1920"
            translation="[0, 480]"
            visible="false"
        />

        <!-- Alphabet jump bar -->
        <LabelList
            id="alphaBar"
            translation="[1740, 120]"
            itemSize="[80, 32]"
            numRows="26"
            visible="false"
        />

        <JellyfinApi id="apiTask" />
    </children>
</component>
