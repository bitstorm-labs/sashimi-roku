<?xml version="1.0" encoding="UTF-8" ?>
<component name="SearchScreen" extends="Group">
    <interface>
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Content sits to the right of the rail (screen shifted +136); all
             coordinates below are within that content area. -->
        <Rectangle width="1784" height="1080" color="#121215" />

        <!-- Rounded search box: magnifier + query readout -->
        <Poster id="searchBoxBg" uri="pkg:/images/card_r16.9.png" width="540" height="78" translation="[56, 64]" />
        <Poster id="searchIcon" uri="pkg:/images/nav_search.png" width="34" height="34" translation="[80, 86]" />
        <Label id="queryLabel" text="Search movies, shows..." color="#666666" width="400"
               height="78" vertAlign="center" translation="[130, 64]" maxLines="1">
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="28" />
        </Label>

        <!-- On-screen keyboard (left column) -->
        <MiniKeyboard id="keyboard" translation="[56, 182]" keyColor="#FFFFFF"
                      focusedKeyColor="#121215" showTextEditBox="false" />

        <!-- Results (right column) -->
        <Label id="statusLabel" text="Search your library — find movies and TV shows"
               color="#888888" width="1040" horizAlign="left" translation="[660, 80]">
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="26" />
        </Label>
        <MarkupGrid
            id="resultsGrid"
            translation="[660, 158]"
            itemSize="[220, 330]"
            itemSpacing="[26, 34]"
            numColumns="4"
            numRows="3"
            drawFocusFeedback="true"
            focusBitmapUri="pkg:/images/focus_ring_r16.9.png"
            itemComponentName="GridItem"
            visible="false"
        />

        <!-- Recent searches (right column, when query empty) -->
        <Label id="recentTitle" text="Recent Searches" color="#FFFFFF" translation="[660, 158]" visible="false">
            <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="30" />
        </Label>
        <LabelList id="recentList" translation="[660, 220]" itemSize="[560, 56]" numRows="10" visible="false" />

        <Timer id="debounceTimer" repeat="false" duration="0.3" />
        <JellyfinApi id="apiTask" />
    </children>
</component>
