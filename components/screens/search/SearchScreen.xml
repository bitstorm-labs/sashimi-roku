<?xml version="1.0" encoding="UTF-8" ?>
<component name="SearchScreen" extends="Group">
    <interface>
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#0e0e1a" />

        <!-- Header -->
        <Rectangle width="1920" height="90" color="#101420" />
        <Label
            id="headerTitle"
            text="Search"
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            translation="[96, 18]"
        />

        <!-- Search buttons + history (left panel) -->
        <ButtonGroup
            id="searchButtons"
            translation="[96, 120]"
            minWidth="420"
            buttonHeight="56"
            itemSpacings="[10]"
            textFont="font:SmallSystemFont"
            focusedTextFont="font:SmallBoldSystemFont"
            textColor="#888888"
            focusedTextColor="#FFFFFF"
            focusBitmapUri="pkg:/images/button_focus.png"
            focusFootprintBitmapUri="pkg:/images/button_unfocus.png"
        />

        <!-- Results grid (right area) -->
        <PosterGrid
            id="resultsGrid"
            translation="[570, 120]"
            basePosterSize="[210, 315]"
            itemSpacing="[30, 60]"
            numColumns="5"
            numRows="3"
            caption1NumLines="2"
            caption1Font="font:SmallestSystemFont"
            caption1Color="#CCCCCC"
            caption2Font="font:SmallestSystemFont"
            caption2Color="#888888"
            visible="false"
        />

        <!-- Status -->
        <Label
            id="statusLabel"
            text="Press OK to search"
            font="font:MediumSystemFont"
            color="#666666"
            horizAlign="center"
            width="1350"
            translation="[570, 400]"
        />

        <JellyfinApi id="apiTask" />
    </children>
</component>
