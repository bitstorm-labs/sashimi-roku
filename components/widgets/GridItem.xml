<?xml version="1.0" encoding="UTF-8" ?>
<component name="GridItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
    </interface>
    <children>
        <!-- Poster with rounded corners (r12, matching HomeItem); the mask
             group scales as a unit on focus. cardBg + dimOverlay live inside so
             they're clipped to the same rounded corners (a square cardBg behind
             makes dark posters read as square-cornered). -->
        <MaskGroup id="posterMask" maskUri="pkg:/images/poster_mask_r12.png"
                   maskSize="[210, 315]" scaleRotateCenter="[105, 157]">
            <Rectangle id="cardBg" width="210" height="315" color="#121215" />
            <Poster
                id="posterImage"
                width="210"
                height="315"
                loadWidth="210"
                loadHeight="315"
                loadDisplayMode="scaleToZoom"
            />
            <Rectangle id="dimOverlay" width="210" height="315" color="#000000" opacity="0.25" />
        </MaskGroup>
        <!-- Rounded focus ring ON TOP at the exact card bounds so it hugs the
             rounded corners without spilling past the grid cell (which clips).
             Scales with the poster on focus. -->
        <Poster id="focusRing" uri="pkg:/images/focus_ring_r16.9.png"
                width="210" height="315" translation="[0, 0]"
                scaleRotateCenter="[105, 157]" opacity="0.0" />
        <!-- Quality badge (bottom-right; 4K = Jellyfin purple, HD/SD = dark slate).
             The colored bg lives in a rounded mask so its corners match the card. -->
        <MaskGroup id="qualityMask" maskUri="pkg:/images/badge_mask_r6.png"
                   maskSize="[50, 30]" translation="[152, 277]" visible="false">
            <Rectangle id="qualityBg" width="50" height="30" color="#0A0A10C8" />
        </MaskGroup>
        <Label id="qualityLabel" text="" color="#FFFFFFFF" horizAlign="center" vertAlign="center"
               width="50" height="30" translation="[152, 277]" visible="false">
            <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="20" />
        </Label>
        <!-- Review rating badge (bottom-left; TMDb logo + community rating).
             Same rounded mask + dark slate as the quality chip, mirrored. -->
        <MaskGroup id="ratingMask" maskUri="pkg:/images/badge_mask_r6.png"
                   maskSize="[88, 30]" translation="[8, 277]" visible="false">
            <Rectangle id="ratingBg" width="88" height="30" color="#0A0A10C8" />
        </MaskGroup>
        <Poster id="tmdbLogo" uri="pkg:/images/tmdb_logo_tv.png" width="34" height="24"
                translation="[16, 280]" visible="false" />
        <Label id="ratingLabel" text="" color="#FFFFFFFF" horizAlign="left" vertAlign="center"
               width="40" height="30" translation="[56, 277]" visible="false">
            <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="20" />
        </Label>
        <!-- tvOS MarqueeText equivalent: scrolls when title overflows -->
        <ScrollingLabel
            id="titleLabel"
            text=""
            color="#BBBBBB"
            maxWidth="210"
            repeatCount="0"
            translation="[0, 330]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="21" />
        </ScrollingLabel>
        <!-- Circular channel card (YouTube libraries/search) -->
        <MaskGroup id="circleMask" maskUri="pkg:/images/circle_mask.png" maskSize="[200, 200]"
                   translation="[5, 40]" visible="false" scaleRotateCenter="[100, 100]">
            <Poster
                id="circlePoster"
                width="200"
                height="200"
                loadWidth="400"
                loadHeight="400"
                loadDisplayMode="scaleToZoom"
            />
        </MaskGroup>
        <Poster id="circleRing" uri="pkg:/images/circle_ring.png" width="216" height="216"
                translation="[-3, 32]" opacity="0.0" />
        <Label
            id="subtitleLabel"
            text=""
            color="#666666"
            width="210"
            maxLines="1"
            translation="[0, 362]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="17" />
        </Label>
    </children>
</component>
