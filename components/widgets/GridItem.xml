<?xml version="1.0" encoding="UTF-8" ?>
<component name="GridItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
    </interface>
    <children>
        <!-- Focus ring (behind poster, slightly larger) -->
        <Rectangle id="focusRing" width="220" height="325" translation="[-5, -5]" color="#5BADE6" opacity="0.0" />
        <Rectangle id="cardBg" width="210" height="315" color="#121215" />
        <Rectangle id="dimOverlay" width="210" height="315" color="#000000" opacity="0.25" />
        <Poster
            id="posterImage"
            width="210"
            height="315"
            loadWidth="210"
            loadHeight="315"
            loadDisplayMode="scaleToZoom"
            scaleRotateCenter="[105, 157]"
        />
        <!-- Quality badge (bottom-right; 4K = Jellyfin purple, HD/SD = dark slate) -->
        <Rectangle id="qualityBg" width="50" height="30" translation="[152, 277]" color="#0A0A10C8" visible="false" />
        <Label id="qualityLabel" text="" color="#FFFFFFFF" horizAlign="center" vertAlign="center"
               width="50" height="30" translation="[152, 277]" visible="false">
            <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="20" />
        </Label>
        <!-- tvOS MarqueeText equivalent: scrolls when title overflows -->
        <ScrollingLabel
            id="titleLabel"
            text=""
            color="#BBBBBB"
            maxWidth="210"
            repeatCount="0"
            translation="[0, 330]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="21" />
        </ScrollingLabel>
        <!-- Circular channel card (YouTube libraries/search) -->
        <MaskGroup id="circleMask" maskUri="pkg:/images/circle_mask.png" maskSize="[200, 200]"
                   translation="[5, 40]" visible="false" scaleRotateCenter="[100, 100]">
            <Poster
                id="circlePoster"
                width="200"
                height="200"
                loadWidth="400"
                loadHeight="400"
                loadDisplayMode="scaleToZoom"
            />
        </MaskGroup>
        <Poster id="circleRing" uri="pkg:/images/circle_ring.png" width="216" height="216"
                translation="[-3, 32]" opacity="0.0" />
        <Label
            id="subtitleLabel"
            text=""
            color="#666666"
            width="210"
            maxLines="1"
            translation="[0, 362]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="17" />
        </Label>
    </children>
</component>
