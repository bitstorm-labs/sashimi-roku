<?xml version="1.0" encoding="UTF-8" ?>
<component name="HeroBanner" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentChanged" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Rounded banner (tvOS: 32:9 card, corner radius 24) -->
        <MaskGroup id="bannerMask" maskUri="pkg:/images/hero_mask_r24.png" maskSize="[1820, 512]">
            <!-- Banner background -->
            <Rectangle id="heroBg" width="1820" height="512" color="#121217" />

            <!-- Backdrop image — right 70%, fitted (tvOS HeroSection) -->
            <Poster
                id="heroImage"
                width="1274"
                height="512"
                loadWidth="1274"
                loadHeight="512"
                loadDisplayMode="scaleToFit"
                translation="[546, 0]"
            />

            <!-- Left fade over the image's left edge (tvOS gradient mask) -->
            <Poster
                uri="pkg:/images/hero_fade_left.png"
                width="500"
                height="512"
                translation="[546, 0]"
            />
            <!-- Text-area solid backing on the far left -->
            <Rectangle width="546" height="512" color="#121217" />

            <!-- Bottom fade -->
            <Poster
                uri="pkg:/images/hero_fade_bottom.png"
                width="1820"
                height="140"
                translation="[0, 372]"
            />
        </MaskGroup>

        <!-- Text overlay — left, tvOS type scale -->
        <Label
            id="heroTitle"
            text=""
            color="#FFFFFF"
            width="920"
            maxLines="2"
            translation="[80, 140]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="64" />
        </Label>
        <Label
            id="heroSubtitle"
            text=""
            color="#E6E6E6"
            width="920"
            maxLines="1"
            translation="[80, 292]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="28" />
        </Label>
        <!-- TMDB logo before rating (tvOS: height 24) -->
        <Poster
            id="tmdbLogo"
            width="34"
            height="24"
            uri="pkg:/images/tmdb_logo_tv.png"
            loadDisplayMode="scaleToFit"
            translation="[80, 338]"
            visible="false"
        />
        <Label
            id="heroMeta"
            text=""
            color="#D9D9D9"
            width="800"
            maxLines="1"
            translation="[126, 340]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="24" />
        </Label>
        <Label
            id="heroOverview"
            text=""
            color="#BFBFBF"
            width="800"
            maxLines="2"
            wrap="true"
            translation="[80, 386]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="22" />
        </Label>

        <!-- Page indicators (tvOS: left-aligned capsules, active 48x5 w/ progress fill) -->
        <Group id="dotsGroup" translation="[80, 470]" />
        <Rectangle id="dotFill" width="0" height="5" color="#FFFFFF" opacity="0.9" translation="[80, 470]" />

        <!-- Focus border (tvOS: accent stroke 4 @ 60%) -->
        <Rectangle id="focusTop" width="1820" height="4" color="#5CADE6" opacity="0.0" />
        <Rectangle id="focusBottom" width="1820" height="4" color="#5CADE6" opacity="0.0" translation="[0, 508]" />
        <Rectangle id="focusLeft" width="4" height="512" color="#5CADE6" opacity="0.0" />
        <Rectangle id="focusRight" width="4" height="512" color="#5CADE6" opacity="0.0" translation="[1816, 0]" />

        <!-- Auto-advance timer (tvOS: 6s) -->
        <Timer id="advanceTimer" repeat="true" duration="6" />
        <!-- Active-dot progress fill animation (runs each slide) -->
        <Animation id="dotAnim" duration="6" repeat="false" easeFunction="linear">
            <FloatFieldInterpolator id="dotAnimInterp" key="[0.0, 1.0]" keyValue="[0.0, 48.0]" fieldToInterp="dotFill.width" />
        </Animation>
    </children>
</component>
