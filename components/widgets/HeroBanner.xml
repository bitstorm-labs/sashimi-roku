<?xml version="1.0" encoding="UTF-8" ?>
<component name="HeroBanner" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentChanged" />
        <field id="selectedItem" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Banner background -->
        <Rectangle id="heroBg" width="1728" height="420" color="#121215" />

        <!-- Backdrop image — RIGHT SIDE, fitted not zoomed -->
        <Poster
            id="heroImage"
            width="1100"
            height="420"
            loadWidth="1100"
            loadHeight="420"
            loadDisplayMode="scaleToFit"
            translation="[628, 0]"
        />

        <!-- Soft fade from left over the image (multiple thin strips for gradient effect) -->
        <Rectangle width="100" height="420" color="#121215" opacity="0.95" translation="[528, 0]" />
        <Rectangle width="80" height="420" color="#121215" opacity="0.7" translation="[628, 0]" />
        <Rectangle width="80" height="420" color="#121215" opacity="0.45" translation="[708, 0]" />
        <Rectangle width="80" height="420" color="#121215" opacity="0.25" translation="[788, 0]" />
        <Rectangle width="80" height="420" color="#121215" opacity="0.1" translation="[868, 0]" />

        <!-- Bottom fade (thin strips) -->
        <Rectangle width="1728" height="40" color="#121215" opacity="0.1" translation="[0, 300]" />
        <Rectangle width="1728" height="40" color="#121215" opacity="0.3" translation="[0, 340]" />
        <Rectangle width="1728" height="40" color="#121215" opacity="0.6" translation="[0, 380]" />

        <!-- Text overlay — bottom left -->
        <Label
            id="heroTitle"
            text=""
            font="font:LargeBoldSystemFont"
            color="#FFFFFF"
            width="700"
            maxLines="2"
            translation="[50, 180]"
        />
        <Label
            id="heroSubtitle"
            text=""
            color="#DDDDDD"
            width="700"
            maxLines="1"
            translation="[50, 275]"
        >
            <Font role="font" uri="font:SystemFontFile" size="22" />
        </Label>
        <!-- TMDB logo before rating -->
        <Poster
            id="tmdbLogo"
            width="60"
            height="18"
            uri="pkg:/images/tmdb_logo.png"
            loadDisplayMode="scaleToFit"
            translation="[50, 308]"
            visible="false"
        />
        <Label
            id="heroMeta"
            text=""
            color="#AAAAAA"
            width="650"
            maxLines="1"
            translation="[116, 305]"
        >
            <Font role="font" uri="font:SystemFontFile" size="18" />
        </Label>
        <Label
            id="heroOverview"
            text=""
            color="#999999"
            width="700"
            maxLines="2"
            wrap="true"
            translation="[50, 335]"
        >
            <Font role="font" uri="font:SystemFontFile" size="20" />
        </Label>

        <!-- Page indicators -->
        <LayoutGroup
            id="dotsGroup"
            layoutDirection="horiz"
            horizAlignment="center"
            itemSpacings="[8]"
            translation="[864, 400]"
        />

        <!-- Focus border -->
        <Rectangle id="focusTop" width="1728" height="3" color="#5BADE6" opacity="0.0" />
        <Rectangle id="focusBottom" width="1728" height="3" color="#5BADE6" opacity="0.0" translation="[0, 417]" />
        <Rectangle id="focusLeft" width="3" height="420" color="#5BADE6" opacity="0.0" />
        <Rectangle id="focusRight" width="3" height="420" color="#5BADE6" opacity="0.0" translation="[1725, 0]" />

        <!-- Auto-advance timer -->
        <Timer id="advanceTimer" repeat="true" duration="6" />
    </children>
</component>
