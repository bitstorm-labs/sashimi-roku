<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <field id="itemHasFocus" type="boolean" onChange="onItemHasFocus" />
        <field id="rowFocusPercent" type="float" onChange="onRowFocusChanged" />
        <field id="width" type="float" onChange="onSizeChanged" />
        <field id="height" type="float" onChange="onSizeChanged" />
    </interface>
    <children>
        <!-- Everything that scales on focus lives in this group (tvOS scaleEffect 1.05) -->
        <Group id="scaleGroup">
            <!-- Card background -->
            <Rectangle id="cardBg" width="220" height="330" color="#1F1F1F" />
            <!-- Portrait/landscape poster with rounded corners -->
            <MaskGroup id="posterMask" maskUri="pkg:/images/poster_mask_r12.png" maskSize="[220, 330]">
                <Poster
                    id="posterImage"
                    width="220"
                    height="330"
                    loadWidth="220"
                    loadHeight="330"
                    loadDisplayMode="scaleToZoom"
                />
                <!-- Continue Watching bottom scrim (tvOS: clear -> black@0.85) -->
                <Poster id="cwScrim" uri="pkg:/images/cw_scrim.png" width="220" height="60" visible="false" />
            </MaskGroup>
            <!-- CW overlay: play glyph + time remaining (tvOS: play.fill accent + "Xh Ym left") -->
            <Poster id="playGlyph" uri="pkg:/images/play_triangle.png" width="18" height="18" visible="false" />
            <Label id="remainingLabel" text="" color="#BFBFBF" visible="false">
                <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="18" />
            </Label>
            <!-- Circular poster (YouTube channels) -->
            <MaskGroup id="circularMask" maskUri="pkg:/images/circle_mask.png" maskSize="[200, 200]" visible="false"
                       scaleRotateCenter="[100, 100]">
                <Poster
                    id="circularPoster"
                    width="200"
                    height="200"
                    loadWidth="200"
                    loadHeight="200"
                    loadDisplayMode="scaleToZoom"
                />
            </MaskGroup>
            <!-- Circular focus ring -->
            <Poster id="circularGlow" width="200" height="200"
                    uri="pkg:/images/circle_ring.png" opacity="0.0" visible="false" />
            <!-- Rectangular focus border (tvOS: accent stroke 4) -->
            <Rectangle id="focusTop" width="220" height="4" color="#FFFFFF" opacity="0.0" />
            <Rectangle id="focusBottom" width="220" height="4" color="#FFFFFF" opacity="0.0" translation="[0, 326]" />
            <Rectangle id="focusLeft" width="4" height="330" color="#FFFFFF" opacity="0.0" />
            <Rectangle id="focusRight" width="4" height="330" color="#FFFFFF" opacity="0.0" translation="[216, 0]" />
            <!-- Quality badge (bottom-right; 4K = Jellyfin purple, HD/SD = dark slate) -->
            <Rectangle id="qualityBg" width="52" height="32" translation="[160, 290]" color="#0A0A10C8" visible="false" />
            <Label id="qualityLabel" text="" color="#FFFFFFFF" horizAlign="center" vertAlign="center"
                   width="52" height="32" translation="[160, 290]" visible="false">
                <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="20" />
            </Label>
            <!-- Watched badge (tvOS: checkmark.circle.fill, green/black palette, 29px) -->
            <Poster id="watchedBadge" uri="pkg:/images/watched_circle.png" width="29" height="29"
                    translation="[185, 6]" visible="false" />
            <!-- "X new" badge (tvOS: 19 bold white on #4A8CBB capsule) -->
            <Poster id="newBadge" uri="pkg:/images/badge_capsule.9.png" width="42" height="28"
                    translation="[172, 6]" visible="false" />
            <Label id="newBadgeLabel" text="" color="#FFFFFF" horizAlign="center" vertAlign="center"
                   width="42" height="28" translation="[172, 6]" visible="false">
                <Font role="font" uri="pkg:/fonts/Roboto-Bold.ttf" size="19" />
            </Label>
            <!-- Progress bar (tvOS: track #404040, fill accent) -->
            <Rectangle id="progressBg" translation="[0, 325]" width="220" height="5" color="#404040" visible="false" />
            <Rectangle id="progressBar" translation="[0, 325]" width="0" height="5" color="#8C5CC7" visible="false" />
        </Group>
        <!-- Title below poster (tvOS: centered 22 medium, single line) -->
        <Label
            id="titleLabel"
            text=""
            color="#FFFFFF"
            width="220"
            maxLines="1"
            ellipsizeOnBoundary="true"
            horizAlign="center"
            translation="[0, 340]"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="22" />
        </Label>
        <!-- Subtitle (Continue Watching cards only: "S1:E5 - Name" / year) -->
        <Label
            id="subtitleLabel"
            text=""
            color="#BFBFBF"
            width="220"
            maxLines="1"
            ellipsizeOnBoundary="true"
            translation="[0, 372]"
            visible="false"
        >
            <Font role="font" uri="pkg:/fonts/Roboto-Medium.ttf" size="20" />
        </Label>
    </children>
</component>
