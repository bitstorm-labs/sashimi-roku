<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <field id="width" type="float" onChange="onSizeChanged" />
        <field id="height" type="float" onChange="onSizeChanged" />
    </interface>
    <children>
        <!-- Card background -->
        <Rectangle id="cardBg" width="180" height="270" color="#181830" />
        <!-- Standard poster (portrait/landscape) -->
        <Poster
            id="posterImage"
            width="180"
            height="270"
            loadWidth="180"
            loadHeight="270"
            loadDisplayMode="scaleToZoom"
            scaleRotateCenter="[90, 135]"
        />
        <!-- Circular poster (YouTube channels) -->
        <MaskGroup id="circularMask" maskUri="pkg:/images/circle_mask.png" maskSize="[180, 180]" visible="false">
            <Poster
                id="circularPoster"
                width="180"
                height="180"
                loadWidth="180"
                loadHeight="180"
                loadDisplayMode="scaleToZoom"
            />
        </MaskGroup>
        <!-- Dim overlay -->
        <Rectangle id="dimOverlay" width="180" height="270" color="#000000" opacity="0.3" />
        <!-- Progress bar -->
        <Rectangle id="progressBg" translation="[0, 262]" width="180" height="6" color="#333333" visible="false" />
        <Rectangle id="progressBar" translation="[0, 262]" width="0" height="6" color="#5BADE6" visible="false" />
        <!-- Title -->
        <Label
            id="titleLabel"
            text=""
            font="font:SmallestSystemFont"
            color="#AAAAAA"
            width="180"
            maxLines="2"
            ellipsizeOnBoundary="true"
            translation="[0, 276]"
        />
        <!-- Subtitle -->
        <Label
            id="subtitleLabel"
            text=""
            font="font:SmallestSystemFont"
            color="#666666"
            width="180"
            maxLines="1"
            ellipsizeOnBoundary="true"
            translation="[0, 306]"
        />
    </children>
</component>
