<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <field id="width" type="float" onChange="onSizeChanged" />
        <field id="height" type="float" onChange="onSizeChanged" />
    </interface>
    <children>
        <!-- Layer 1: Focus ring (largest, behind everything) -->
        <Rectangle id="focusRing" width="206" height="306" translation="[-3, -3]" color="#5BADE6" visible="false" />
        <!-- Layer 2: Card background (shows while image loads) -->
        <Rectangle id="cardBg" width="200" height="300" color="#1a1a2a" />
        <!-- Layer 3: Poster image -->
        <Poster
            id="posterImage"
            width="200"
            height="300"
            loadWidth="200"
            loadHeight="300"
            loadDisplayMode="scaleToZoom"
            scaleRotateCenter="[100, 150]"
        />
        <!-- Layer 3b: Circular poster (YouTube, hidden by default) -->
        <MaskGroup id="circularMask" maskUri="pkg:/images/circle_mask.png" maskSize="[180, 180]" visible="false">
            <Poster
                id="circularPoster"
                width="180"
                height="180"
                loadWidth="180"
                loadHeight="180"
                loadDisplayMode="scaleToZoom"
            />
        </MaskGroup>
        <!-- Layer 4: Dim overlay on poster -->
        <Rectangle id="dimOverlay" width="200" height="300" color="#000000" opacity="0.25" />
        <!-- Layer 5: Progress bar at bottom of poster -->
        <Rectangle id="progressBg" translation="[0, 294]" width="200" height="6" color="#333333" visible="false" />
        <Rectangle id="progressBar" translation="[0, 294]" width="0" height="6" color="#5BADE6" visible="false" />
        <!-- Layer 6: Hero gradient + text (hidden by default) -->
        <Rectangle id="heroGradient" width="700" height="180" color="#121215" opacity="0.0" visible="false" />
        <Label id="heroTitleLabel" text="" font="font:LargeBoldSystemFont" color="#FFFFFF" width="600" maxLines="2" visible="false" />
        <Label id="heroSubtitleLabel" text="" font="font:SmallSystemFont" color="#BBBBBB" width="600" maxLines="1" visible="false" />
        <!-- Layer 7: Title and subtitle below poster -->
        <Label
            id="titleLabel"
            text=""
            font="font:SmallestBoldSystemFont"
            color="#BBBBBB"
            width="200"
            maxLines="1"
            ellipsizeOnBoundary="true"
            translation="[0, 310]"
        />
        <Label
            id="subtitleLabel"
            text=""
            font="font:SmallestSystemFont"
            color="#666666"
            width="200"
            maxLines="1"
            ellipsizeOnBoundary="true"
            translation="[0, 332]"
        />
    </children>
</component>
