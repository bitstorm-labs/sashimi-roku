<?xml version="1.0" encoding="UTF-8" ?>
<component name="HomeItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onItemContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
        <field id="width" type="float" onChange="onSizeChanged" />
        <field id="height" type="float" onChange="onSizeChanged" />
    </interface>
    <children>
        <!-- Card background -->
        <Rectangle id="cardBg" width="220" height="330" color="#181830" />
        <!-- Dim overlay (fades out on focus) -->
        <Rectangle id="dimOverlay" width="220" height="330" color="#000000" opacity="0.4" />
        <!-- Poster image -->
        <Poster
            id="posterImage"
            width="220"
            height="330"
            loadWidth="220"
            loadHeight="330"
            loadDisplayMode="scaleToZoom"
            scaleRotateCenter="[110, 165]"
        />
        <!-- Progress bar -->
        <Rectangle id="progressBg" translation="[0, 322]" width="220" height="8" color="#333333" visible="false" />
        <Rectangle id="progressBar" translation="[0, 322]" width="0" height="8" color="#00CC66" visible="false" />
        <!-- Title -->
        <Label
            id="titleLabel"
            text=""
            font="font:SmallestSystemFont"
            color="#AAAAAA"
            width="220"
            maxLines="2"
            ellipsizeOnBoundary="true"
            translation="[0, 336]"
        />
        <!-- Subtitle -->
        <Label
            id="subtitleLabel"
            text=""
            font="font:SmallestSystemFont"
            color="#555555"
            width="220"
            maxLines="1"
            ellipsizeOnBoundary="true"
            translation="[0, 370]"
        />
    </children>
</component>
