<?xml version="1.0" encoding="UTF-8" ?>
<component name="TabBar" extends="Group">
    <interface>
        <!-- 0=Home 1=Library 2=Search 3=Settings -->
        <field id="selectedIndex" type="integer" value="0" onChange="onSelectedIndexChanged" />
        <field id="tabSelected" type="integer" alwaysNotify="true" />
        <field id="descend" type="boolean" alwaysNotify="true" />
    </interface>
    <children>
        <!-- Pills are built in code and centered as a group -->
        <Group id="pillsGroup" />
    </children>
</component>
