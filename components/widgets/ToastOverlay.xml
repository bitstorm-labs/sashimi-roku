<?xml version="1.0" encoding="UTF-8" ?>
<component name="ToastOverlay" extends="Group">
    <interface>
        <field id="showToast" type="assocarray" alwaysNotify="true" />
    </interface>
    <children>
        <Rectangle
            id="toastBg"
            visible="false"
            color="#333333"
            opacity="0.9"
            width="600"
            height="80"
            translation="[660, 50]"

        >
            <Label
                id="toastLabel"
                text=""
                font="font:SmallSystemFont"
                color="#FFFFFF"
                width="560"
                height="80"
                horizAlign="center"
                vertAlign="center"
                translation="[20, 0]"
            />
        </Rectangle>
        <Timer id="dismissTimer" repeat="false" duration="3" />
    </children>
</component>
